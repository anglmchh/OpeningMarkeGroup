<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">

    <!-- ════════════════════════════════════════════════════════════════════
         CRON: Sincronización de Productos (diario, 02:00 AM)
         ════════════════════════════════════════════════════════════════════ -->
    <record id="ir_cron_seped_sync_products" model="ir.cron">
        <field name="name">SEPED - Sincronizar Productos</field>
        <field name="model_id" ref="model_seped_config"/>
        <field name="state">code</field>
        <field name="code">model.cron_sync_products()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="numbercall">-1</field>
        <field name="active">False</field>
        <field name="nextcall" eval="(datetime.now() + timedelta(days=1)).replace(hour=2, minute=0, second=0).strftime('%Y-%m-%d %H:%M:%S')"/>
    </record>

    <!-- ════════════════════════════════════════════════════════════════════
         CRON: Actualización de Stock (cada hora)
         ════════════════════════════════════════════════════════════════════ -->
    <record id="ir_cron_seped_sync_stock" model="ir.cron">
        <field name="name">SEPED - Actualizar Stock</field>
        <field name="model_id" ref="model_seped_config"/>
        <field name="state">code</field>
        <field name="code">model.cron_sync_stock()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">hours</field>
        <field name="numbercall">-1</field>
        <field name="active">False</field>
        <field name="nextcall" eval="(datetime.now() + timedelta(hours=1)).strftime('%Y-%m-%d %H:%M:%S')"/>
    </record>

    <!-- ════════════════════════════════════════════════════════════════════
         CRON: Sincronización de Clientes (diario, 03:00 AM)
         ════════════════════════════════════════════════════════════════════ -->
    <record id="ir_cron_seped_sync_clients" model="ir.cron">
        <field name="name">SEPED - Sincronizar Clientes</field>
        <field name="model_id" ref="model_seped_config"/>
        <field name="state">code</field>
        <field name="code">model.cron_sync_clients()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="numbercall">-1</field>
        <field name="active">False</field>
        <field name="nextcall" eval="(datetime.now() + timedelta(days=1)).replace(hour=3, minute=0, second=0).strftime('%Y-%m-%d %H:%M:%S')"/>
    </record>

</odoo>
