<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ════════════════════════════════════════════════════════════════════
         Vistas del modelo seped.config
         ════════════════════════════════════════════════════════════════════ -->

    <!-- Vista Lista -->
    <record id="seped_config_view_tree" model="ir.ui.view">
        <field name="name">seped.config.list</field>
        <field name="model">seped.config</field>
        <field name="arch" type="xml">
            <tree string="Configuraciones SEPED">
                <field name="name"/>
                <field name="base_url"/>
                <field name="codisb"/>
                <field name="last_product_sync" widget="datetime"/>
                <field name="last_client_sync" widget="datetime"/>
                <field name="last_vendor_sync" widget="datetime"/>
                <field name="last_invoice_sync" widget="datetime"/>
                <field name="last_ventares_sync" widget="datetime"/>
                <field name="active"/>
            </tree>
        </field>
    </record>

    <!-- Vista Formulario -->
    <record id="seped_config_view_form" model="ir.ui.view">
        <field name="name">seped.config.form</field>
        <field name="model">seped.config</field>
        <field name="arch" type="xml">
            <form string="Configuración SEPED">
                <sheet>
                    <!-- Título -->
                    <div class="oe_title">
                        <label for="name" string="Nombre de la Configuración"/>
                        <h1><field name="name" placeholder="SEPED Configuración Principal"/></h1>
                    </div>

                    <!-- Estadísticas rápidas -->
                    <div class="oe_button_box" name="button_box">
                        <button name="action_test_connection"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-check-circle"
                                string="Probar Conexión"/>
                    </div>

                    <group>
                        <group string="Conexión API">
                            <field name="base_url" placeholder="https://seped.openingmarketgroup.com"/>
                            <field name="api_key" password="True" placeholder="Ingrese su API Key..."/>
                            <field name="codisb" placeholder="Ej: 507572617"/>
                            <field name="active"/>
                        </group>
                        <group string="Opciones de Sincronización">
                            <field name="batch_size"/>
                        </group>
                    </group>

                    <group string="Configuración de Pedidos">
                        <group>
                            <field name="order_estado_filter"/>
                            <field name="order_estado_procesado"/>
                            <field name="order_estado_facturado"/>
                        </group>
                        <group>
                            <field name="order_limit"/>
                        </group>
                    </group>

                    <!-- Botones de sincronización -->
                    <group string="Acciones de Sincronización">
                        <div class="o_row">
                            <button name="action_sync_products"
                                    type="object"
                                    string="Sincronizar Productos"
                                    class="btn-primary"
                                    icon="fa-refresh"
                                    confirm="¿Desea enviar todos los productos activos a SEPED?"/>
                            <button name="action_sync_stock"
                                    type="object"
                                    string="Actualizar Stock"
                                    class="btn-secondary"
                                    icon="fa-cubes"
                                    confirm="¿Desea actualizar las cantidades de stock en SEPED?"/>
                            <button name="action_sync_clients"
                                    type="object"
                                    string="Clientes"
                                    class="btn-secondary"
                                    icon="fa-users"
                                    confirm="¿Desea enviar todos los clientes activos a SEPED?"/>
                            <button name="action_sync_vendors"
                                    type="object"
                                    string="Proveedores"
                                    class="btn-secondary"
                                    icon="fa-truck"
                                    confirm="¿Desea enviar todos los proveedores activos a SEPED?"/>
                            <button name="action_sync_invoices"
                                    type="object"
                                    string="Facturas"
                                    class="btn-secondary"
                                    icon="fa-file-text-o"
                                    confirm="¿Desea sincronizar las facturas de Odoo con SEPED?"/>
                            <button name="action_sync_ventares"
                                    type="object"
                                    string="Resumen Ventas"
                                    class="btn-secondary"
                                    icon="fa-bar-chart"
                                    confirm="¿Desea enviar el resumen de ventas del día a SEPED?"/>
                        </div>
                        <div class="o_row mt-2">
                             <button name="action_sync_cxc"
                                    type="object"
                                    string="CxC"
                                    class="btn-secondary"
                                    icon="fa-money"
                                    confirm="¿Desea enviar las Cuentas por Cobrar pendientes?"/>
                            <button name="action_sync_cxp"
                                    type="object"
                                    string="CxP"
                                    class="btn-secondary"
                                    icon="fa-credit-card"
                                    confirm="¿Desea enviar las Cuentas por Pagar pendientes?"/>
                            <button name="action_sync_banks"
                                    type="object"
                                    string="Bancos"
                                    class="btn-secondary"
                                    icon="fa-university"
                                    confirm="¿Desea enviar las cuentas bancarias?"/>
                            <button name="action_sync_monedas"
                                    type="object"
                                    string="Monedas"
                                    class="btn-secondary"
                                    icon="fa-usd"
                                    confirm="¿Desea enviar las monedas y tasas?"/>
                        </div>
                        <div class="o_row mt-2">
                             <button name="action_sync_categories"
                                    type="object"
                                    string="Categorías"
                                    class="btn-secondary"
                                    icon="fa-tags"
                                    confirm="¿Desea enviar las categorías de productos?"/>
                            <button name="action_sync_vendedores"
                                    type="object"
                                    string="Vendedores"
                                    class="btn-secondary"
                                    icon="fa-id-card-o"
                                    confirm="¿Desea enviar los vendedores activos?"/>
                            <button name="action_sync_lotes"
                                    type="object"
                                    string="Lotes"
                                    class="btn-secondary"
                                    icon="fa-barcode"
                                    confirm="¿Desea enviar los lotes y existencias?"/>
                            <button name="action_sync_prodfalla"
                                    type="object"
                                    string="Prod. Falla"
                                    class="btn-secondary"
                                    icon="fa-exclamation-triangle"
                                    confirm="¿Desea enviar los productos sin stock o con falla?"/>
                        </div>
                    </group>

                    <!-- Pedidos SEPED -->
                    <group string="Pedidos SEPED">
                        <div class="o_row">
                            <button name="action_fetch_orders"
                                    type="object"
                                    string="Obtener Pedidos Pendientes"
                                    class="btn-primary"
                                    icon="fa-download"
                                    confirm="¿Desea consultar pedidos pendientes en SEPED e importarlos como borradores?"/>
                        </div>
                    </group>

                    <!-- Estadísticas de última sincronización -->
                    <group string="Historial de Sincronización">
                        <group>
                            <field name="last_product_sync"/>
                            <field name="last_stock_update"/>
                            <field name="last_client_sync"/>
                            <field name="last_vendor_sync"/>
                            <field name="last_vendedor_sync"/>
                            <field name="last_moneda_sync"/>
                        </group>
                        <group>
                            <field name="last_invoice_sync"/>
                            <field name="last_ventares_sync"/>
                            <field name="last_cxc_sync"/>
                            <field name="last_cxp_sync"/>
                            <field name="last_bank_sync"/>
                            <field name="last_category_sync"/>
                            <field name="last_lote_sync"/>
                            <field name="last_prodfalla_sync"/>
                        </group>
                    </group>

                    <!-- Notas -->
                    <group>
                        <field name="note" placeholder="Notas internas sobre esta configuración..."/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action para abrir la configuración -->
    <record id="action_seped_config" model="ir.actions.act_window">
        <field name="name">Configuración SEPED</field>
        <field name="res_model">seped.config</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                ¡Crea tu primera configuración SEPED!
            </p>
            <p>
                Ingresa la URL base, la API Key y el código de distribuidor
                para comenzar a sincronizar productos, stock y clientes con SEPED.
            </p>
        </field>
    </record>

</odoo>
